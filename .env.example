# ============================================================
# Drawdown Radar — configurazione (copiare in .env)
# NESSUN valore reale in questo file: i segreti vivono solo in .env,
# che è escluso dal repository (.gitignore).
# Il bootstrap (scripts/bootstrap.sh) genera i segreti automaticamente.
# ============================================================

# --- modalità: demo (nessuna API key necessaria) | live ---
DDR_APP_MODE=demo

# --- database (usato da docker compose) ---
DDR_DB_NAME=ddr
DDR_DB_USER=ddr
DDR_DB_PASSWORD=CAMBIAMI-password-db-casuale

# --- accesso privato mono-utente: nessuna registrazione ---
DDR_ADMIN_USERNAME=admin
DDR_ADMIN_PASSWORD=CAMBIAMI-password-lunga-e-unica
DDR_SESSION_SECRET=CAMBIAMI-64-caratteri-casuali
# true SOLO se l'istanza è raggiungibile esclusivamente via Tailscale/VPN/access proxy
DDR_AUTH_DISABLED=false
# true in produzione con HTTPS; false in sviluppo locale http o se si accede
# via IP Tailscale senza TLS (i browser rifiutano i cookie Secure su http remoto)
DDR_COOKIE_SECURE=true

# --- esposizione web ---
# dominio reale (es. radar.example.org) per TLS automatico Let's Encrypt;
# ":80" = solo HTTP locale (dietro Tailscale/VPN)
DDR_DOMAIN=:80
DDR_HTTP_PORT=80
DDR_HTTPS_PORT=443

# --- provider dati di mercato (sostituibile; vedi SOURCE_REGISTRY.md) ---
# demo | alpaca (reale, piano free IEX) | eodhd_stub | tiingo_stub
DDR_MARKET_DATA_PROVIDER=demo
DDR_MARKET_DATA_API_KEY=
# Alpaca Market Data (https://alpaca.markets — account gratuito, chiavi API
# dalla dashboard; feed IEX ritardato/parziale). SOLO dati: nessun ordine.
DDR_ALPACA_KEY_ID=
DDR_ALPACA_SECRET_KEY=

# --- universo live ---
# auto: scoperta automatica dell'intero listino USA dal provider (default consigliato)
# explicit: solo la lista DDR_UNIVERSE_TICKERS / UI (max 500)
DDR_UNIVERSE_MODE=explicit
DDR_UNIVERSE_TICKERS=
# screening coppie crypto */USD (limiti: nessun filing/market cap -> confidence max C)
DDR_CRYPTO_ENABLED=false
# storico iniziale in auto-discovery (giorni di calendario, full market)
DDR_DISCOVER_BACKFILL_DAYS=130
# benchmark per gli outcome relativi (ETF proxy Russell 2000)
DDR_BENCHMARK_TICKER=IWM
# storico iniziale per il backfill (giorni di calendario)
DDR_BACKFILL_DAYS=400

# --- fonti ufficiali ---
# SEC EDGAR è gratuita: richiede solo uno User-Agent identificabile
# (fair access policy), es. "Nome Cognome email@example.com"
DDR_SEC_EDGAR_ENABLED=false
DDR_SEC_USER_AGENT=
DDR_OPENFDA_API_KEY=
DDR_CLINICALTRIALS_ENABLED=false
DDR_NASDAQ_HALTS_ENABLED=false
DDR_FINRA_ENABLED=false
# news discovery (metadati e link, mai contenuti integrali):
#   gdelt = gratuito, aperto, NESSUNA chiave (default; fair use 1 req/5s)
#   brave = richiede piano/chiave a pagamento (https://brave.com/search/api/)
DDR_NEWS_DISCOVERY_PROVIDER=gdelt
DDR_NEWS_DISCOVERY_API_KEY=

# --- AI opzionale (l'app funziona interamente senza) ---
DDR_AI_ENABLED=false
DDR_AI_PROVIDER=disabled
DDR_AI_API_KEY=
DDR_AI_MODEL=claude-sonnet-5
DDR_AI_MONTHLY_BUDGET_EUR=20

# --- notifiche esterne: none (solo in-app) | telegram ---
# Telegram: bot via @BotFather -> token; chat id dalla api getUpdates
DDR_NOTIFY_CHANNEL=none
DDR_TELEGRAM_BOT_TOKEN=
DDR_TELEGRAM_CHAT_ID=

# --- backup cifrato (scripts/backup.sh, Restic) ---
# es. sftp:utente@host:/backup/ddr oppure s3:https://endpoint/bucket
RESTIC_REPOSITORY=
RESTIC_PASSWORD=
