# Caddy: TLS automatico (Let's Encrypt) quando DDR_DOMAIN è un dominio reale.
# Con DDR_DOMAIN=":80" (default) l'istanza è solo locale/rete privata —
# adatta a Tailscale o a un access proxy davanti.

{$DDR_DOMAIN::80} {
	encode zstd gzip

	header {
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy no-referrer
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		# CSP prudente: nessun host esterno. 'unsafe-inline' su script è
		# necessario per lo script inline di bootstrap di SvelteKit (SPA);
		# tutto il resto resta confinato a 'self'.
		Content-Security-Policy "default-src 'self'; img-src 'self' data:; font-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; connect-src 'self'; frame-ancestors 'none'"
		-Server
	}

	# API verso il backend interno (mai esposto direttamente)
	handle /api/* {
		reverse_proxy api:8000
	}

	# SPA statica con fallback client-side routing
	handle {
		root * /srv/www
		try_files {path} /index.html
		file_server
	}
}
